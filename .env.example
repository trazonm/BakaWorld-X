# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bakaworld
DB_USER=bakaworld
DB_PASSWORD=changeme

# JWT Secret (change this to a random secure string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Real-Debrid API
REAL_DEBRID_AUTH=your_realdebrid_api_key

# Jackett API (optional, for torrent search)
JACKETT_API_KEY=your_jackett_api_key

# Application Port
PORT=3000

# Consumet-compatible streaming metadata API (movies, TV, anime watch). Required in production if not using the dev default.
# Example: http://host.docker.internal:6000  or  https://your-consumet.example.com
# CONSUMET_BASE_URL=

# Spotify → YouTube (yt-dlp): optional free Spotify API for better search — see SPOTIFY_SETUP.md
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# If YouTube returns HTTP 403: export browser cookies (Netscape format) and point yt-dlp at them
# YT_DLP_COOKIES=/absolute/path/to/cookies.txt
# Optional override for yt-dlp YouTube extractor (default tries several player_client modes)
# YT_DLP_YOUTUBE_EXTRACTOR_ARGS=youtube:player_client=android,web